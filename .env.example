# Crawlyx Docker Environment Configuration

# Host binding for the application
# - 127.0.0.1 = localhost only (local use, recommended)
# - 0.0.0.0 = all interfaces (accessible from network)
HOST_BINDING=127.0.0.1

# The port binding for the application
EXTERNAL_PORT=5000

# Secret key used to sign session cookies (sessions only separate browser
# tabs — there are no user accounts). If left unset, an ephemeral random key
# is generated at startup; sessions will not survive a restart.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=
